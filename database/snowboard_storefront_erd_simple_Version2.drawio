<mxfile host="app.diagrams.net" type="device">
  <diagram id="snowboard-erd-simple" name="Snowboard Storefront ERD (Overview)">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- accounts -->
        <mxCell id="users" value="users" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="120" y="80" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="profile" value="profile" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="120" y="220" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- catalog -->
        <mxCell id="category" value="category" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="620" y="80" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="product" value="product" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="620" y="220" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- commerce -->
        <mxCell id="cart" value="cart" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="370" y="220" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="cart_items" value="cart_items" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="370" y="360" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="orders" value="orders" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="900" y="220" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="order_items" value="order_items" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="900" y="360" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- messaging -->
        <mxCell id="conversation" value="conversation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="120" y="420" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="message" value="message" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="120" y="560" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- relationships (crow's foot) -->
        <mxCell id="s_users_profile" value="1:1" style="edgeStyle=entityRelationEdgeStyle;rounded=0;startArrow=ERone;startFill=0;endArrow=ERone;endFill=0;fontSize=10;" edge="1" parent="1" source="users" target="profile">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s_users_cart" value="1:1" style="edgeStyle=entityRelationEdgeStyle;rounded=0;startArrow=ERone;startFill=0;endArrow=ERone;endFill=0;fontSize=10;" edge="1" parent="1" source="users" target="cart">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s_users_orders" value="1:N" style="edgeStyle=entityRelationEdgeStyle;rounded=0;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;fontSize=10;" edge="1" parent="1" source="users" target="orders">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s_users_conv" value="customer / expert (1:N)" style="edgeStyle=entityRelationEdgeStyle;rounded=0;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;fontSize=9;dashed=1;" edge="1" parent="1" source="users" target="conversation">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s_users_msg" value="sender (1:N)" style="edgeStyle=entityRelationEdgeStyle;rounded=0;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;fontSize=9;dashed=1;" edge="1" parent="1" source="users" target="message">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s_cart_ci" value="1:N" style="edgeStyle=entityRelationEdgeStyle;rounded=0;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;fontSize=10;" edge="1" parent="1" source="cart" target="cart_items">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s_product_ci" value="1:N" style="edgeStyle=entityRelationEdgeStyle;rounded=0;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;fontSize=10;" edge="1" parent="1" source="product" target="cart_items">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s_category_product" value="1:N" style="edgeStyle=entityRelationEdgeStyle;rounded=0;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;fontSize=10;" edge="1" parent="1" source="category" target="product">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s_orders_oi" value="1:N" style="edgeStyle=entityRelationEdgeStyle;rounded=0;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;fontSize=10;" edge="1" parent="1" source="orders" target="order_items">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s_product_oi" value="1:N" style="edgeStyle=entityRelationEdgeStyle;rounded=0;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;fontSize=10;" edge="1" parent="1" source="product" target="order_items">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s_conv_msg" value="1:N" style="edgeStyle=entityRelationEdgeStyle;rounded=0;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;fontSize=10;" edge="1" parent="1" source="conversation" target="message">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- legend -->
        <mxCell id="legend" value="Overview ERD — 10 tables&#10;1:1 = one-to-one    1:N = one-to-many&#10;Dashed = multiple FKs into users&#10;blue=accounts  green=catalog  orange=commerce  purple=messaging" style="text;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fillColor=#f5f5f5;strokeColor=#666666;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="620" y="420" width="440" height="90" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>